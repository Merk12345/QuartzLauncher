# local weird files
node
quartz-launcher@0.1.0

# avoid committing third-party converted packages by default
assets/packages/*.quartz
assets/packages/*.quartz.*

# keep only Quartz-owned sample/test packages
!assets/packages/HelloQuartz.quartz
!assets/packages/HelloQuartzNative.quartz
!assets/packages/QuartzNativeTemplate.quartz
!assets/packages/itzrealmerk.first-native-test.quartz

