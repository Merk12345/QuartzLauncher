# dependencies
node_modules/

# env/secrets
.env
.env.*
*.pem
*.key

# release/build outputs
releases/builds/
releases/*.zip
dist/
out/

# backups/temp/generated junk
backups/
checkpoints/
tmp/
build-quartz/
*.bak
*.backup*
*.broken*
main.js.backup*
preload.js.backup*
package.json.backup*
src/*.backup*
src/*.broken*
